const CONTROLS_CATS = [
  {name:"Network Security", color:"#E6F1FB", dot:"#185FA5", controls:["Purdue Model / IT-OT DMZ segmentation","Unidirectional gateways","OT-specific firewalls (protocol-aware)","Network microsegmentation for OT zones","Wireless IDS (WIDS)","OT network traffic whitelisting"]},
  {name:"Access & Identity", color:"#EEEDFE", dot:"#534AB7", controls:["MFA for all OT remote access","Zero Trust Network Access (ZTNA)","Privileged Access Management (PAM)","Role-based access control (RBAC)","Least privilege enforcement","Jump server / bastion host for OT","Vendor access time-limiting and recording"]},
  {name:"Endpoint Hardening", color:"#FAEEDA", dot:"#854F0B", controls:["Application allowlisting on HMI/EWS","OT-specific endpoint detection","USB port controls","Disable unnecessary services/ports","PLC program integrity monitoring","Engineering workstation hardening"]},
  {name:"Vulnerability Management", color:"#E1F5EE", dot:"#0F6E56", controls:["OT-specific vulnerability scanning (passive)","Compensating controls for unpatchable systems","Virtual patching via IDS/IPS","SBOM for OT software","ICS-CERT advisory monitoring","Vendor patch management programme"]},
  {name:"Detection & Monitoring", color:"#FCEBEB", dot:"#A32D2D", controls:["Passive OT NDR (Dragos, Claroty, Nozomi)","SIEM with OT protocol parsers","Level 0 process value monitoring","OT behavioural baselining","ICS protocol command monitoring","Remote access session logging","OT SOC integration"]},
  {name:"Incident Response", color:"#F1EFE8", dot:"#444441", controls:["OT-specific IR plan","OT tabletop exercises","OT forensics capability","Safe-state procedures for OT isolation","Out-of-band OT communication plan","Post-incident OT review process"]},
  {name:"Physical Security", color:"#FAC775", dot:"#633806", controls:["Physical access controls for control rooms","Tamper-evident seals on ICS cabinets","CCTV monitoring of OT areas","USB/removable media controls","Visitor access management","Hardware asset integrity checks"]},
  {name:"Resilience & Recovery", color:"#C0DD97", dot:"#27500A", controls:["Offline, tested OT backups (3-2-1)","Immutable backup repositories","Tested recovery procedures (quarterly)","Manual override / safe-state procedures","Redundant OT communication paths","Business continuity plan for OT outage"]},
  {name:"Governance & Policy", color:"#B5D4F4", dot:"#0C447C", controls:["OT security policy and standards","Security awareness training for OT staff","Supplier security requirements (procurement)","OT risk assessment programme","Separation of duties for critical functions","OT cybersecurity ownership (CISO/OT lead)"]},
];

function sevClass(s){return s==="Critical"?"pill-crit":s==="High"?"pill-high":s==="Medium"?"pill-med":"pill-low"}
function sevOrder(s){return{Critical:0,High:1,Medium:2,Low:3}[s]??4}

function renderStats(){
  const cats=[...new Set(THREATS.map(t=>t.cat))].sort();
  const zones=[...new Set(THREATS.flatMap(t=>t.zone))].sort();
  const fCat=document.getElementById('f-cat');
  const fZone=document.getElementById('f-zone');
  cats.forEach(c=>{const o=document.createElement('option');o.value=c;o.textContent=c;fCat.appendChild(o)});
  zones.forEach(z=>{const o=document.createElement('option');o.value=z;o.textContent=z;fZone.appendChild(o)});
  const bySev={Critical:0,High:0,Medium:0,Low:0};
  THREATS.forEach(t=>bySev[t.sev]++);
  document.getElementById('stat-row').innerHTML=`
    <div class="stat"><div class="stat-lbl">Total threats</div><div class="stat-val">${THREATS.length}</div></div>
    <div class="stat"><div class="stat-lbl">Critical</div><div class="stat-val red">${bySev.Critical}</div></div>
    <div class="stat"><div class="stat-lbl">High</div><div class="stat-val amber">${bySev.High}</div></div>
    <div class="stat"><div class="stat-lbl">Medium / Low</div><div class="stat-val green">${bySev.Medium+bySev.Low}</div></div>
    <div class="stat"><div class="stat-lbl">Threat categories</div><div class="stat-val blue">${cats.length}</div></div>`;
}

function renderThreats(){
  const fCat=document.getElementById('f-cat').value;
  const fSev=document.getElementById('f-sev').value;
  const fZone=document.getElementById('f-zone').value;
  const fSearch=document.getElementById('f-search').value.toLowerCase();
  const filtered=THREATS.filter(t=>{
    if(fCat&&t.cat!==fCat)return false;
    if(fSev&&t.sev!==fSev)return false;
    if(fZone&&!t.zone.includes(fZone))return false;
    if(fSearch&&!t.name.toLowerCase().includes(fSearch)&&!t.desc.toLowerCase().includes(fSearch))return false;
    return true;
  }).sort((a,b)=>sevOrder(a.sev)-sevOrder(b.sev));

  document.getElementById('threat-count-badge').textContent=`${filtered.length} threat${filtered.length!==1?'s':''}`;

  document.getElementById('threat-grid').innerHTML=filtered.map(t=>`
    <div class="threat-card" id="card-${t.id}">
      <div class="threat-head" onclick="toggleCard('${t.id}')">
        <div class="threat-icon" style="background:${t.color}">${t.icon}</div>
        <div class="threat-meta">
          <div class="threat-name">${t.name}</div>
          <div class="threat-sub">${t.id} · ${t.zone.join(', ')} zone${t.zone.length>1?'s':''}</div>
        </div>
        <div class="threat-badges">
          <span class="pill ${sevClass(t.sev)}">${t.sev}</span>
          <span class="pill pill-cat">${t.cat}</span>
          <span style="font-size:11px;color:var(--muted)">${t.controls.length} controls</span>
        </div>
        <div class="expand-icon">⌄</div>
      </div>
      <div class="threat-body">
        <div class="body-desc">${t.desc}</div>
        <div class="body-cols">
          <div>
            <div class="col-head red">Attack techniques (TTPs)</div>
            <ul class="ctrl-list">${t.ttps.map(p=>`<li class="ctrl-item"><div class="ctrl-dot amber"></div>${p}</li>`).join('')}</ul>
          </div>
          <div>
            <div class="col-head green">Recommended controls</div>
            <ul class="ctrl-list">${t.controls.map(c=>`<li class="ctrl-item"><div class="ctrl-dot green"></div>${c}</li>`).join('')}</ul>
          </div>
        </div>
        <div class="framework-row">
          <span style="font-size:11px;color:var(--muted);margin-right:4px">Frameworks:</span>
          ${t.frameworks.map(f=>{
            const cls=f.includes('NIST 800')||f.includes('NIST CSF')||f.includes('NERC')?'fw-nist':f.includes('62443')||f.includes('61511')||f.includes('ISA')?'fw-iec':f.includes('CISA')?'fw-cisa':'fw-mitre';
            return `<span class="fw-badge ${cls}">${f}</span>`;
          }).join('')}
        </div>
      </div>
    </div>`).join('');
}

function toggleCard(id){
  const card=document.getElementById('card-'+id);
  card.classList.toggle('open');
}

function renderMatrix(){
  const zones=['Control','Field','Network','Safety'];
  const controlGroups=['Network Security','Access & Identity','Endpoint Hardening','Vulnerability Mgmt','Detection & Monitoring','IR & Recovery','Physical Security'];
  const sorted=[...THREATS].sort((a,b)=>sevOrder(a.sev)-sevOrder(b.sev));
  let html=`<thead><tr><th>Threat</th><th>Sev</th>`;
  controlGroups.forEach(g=>{html+=`<th>${g}</th>`});
  html+=`</tr></thead><tbody>`;
  sorted.forEach(t=>{
    const ctrlMap={
      'Network Security':['segmentation','DMZ','firewall','gateway','wireless','subnet','network','VLAN'],
      'Access & Identity':['MFA','access','credential','privilege','RBAC','least-privilege','zero trust','ZTNA','PAM','password','authentication','jump server','vendor access'],
      'Endpoint Hardening':['allowlist','endpoint','USB','hardening','workstation','application','disable','PLC program','port','service'],
      'Vulnerability Mgmt':['patch','vulnerability','CVE','firmware','SBOM','advisory','compensating','virtual patch'],
      'Detection & Monitoring':['monitor','detection','NDR','SIEM','baseline','log','SOC','anomaly','visibility','alert'],
      'IR & Recovery':['incident','response','backup','recovery','exercise','tabletop','forensics','restore','plan'],
      'Physical Security':['physical','CCTV','tamper','USB','visitor','hardware','seal','access control']
    };
    html+=`<tr><td style="font-size:12px;max-width:180px">${t.icon} ${t.name}</td><td><span class="pill ${sevClass(t.sev)}" style="font-size:10px">${t.sev}</span></td>`;
    controlGroups.forEach(g=>{
      const keywords=ctrlMap[g]||[];
      const match=t.controls.some(c=>keywords.some(k=>c.toLowerCase().includes(k)));
      html+=`<td><div class="dot-cell"><div class="ctrl-dot-sm ${match?'has':'none'}" title="${match?'Control applies':'Not mapped'}"></div></div></td>`;
    });
    html+=`</tr>`;
  });
  html+=`</tbody>`;
  document.getElementById('matrix-tbl').innerHTML=html;
}

function renderControls(){
  const fCat=document.getElementById('fc-cat').value;
  const fSearch=document.getElementById('fc-search').value.toLowerCase();
  let html='';
  const filtered=CONTROLS_CATS.filter(c=>{
    if(fCat&&c.name!==fCat)return false;
    if(fSearch){
      const matchName=c.name.toLowerCase().includes(fSearch);
      const matchCtrl=c.controls.some(x=>x.toLowerCase().includes(fSearch));
      if(!matchName&&!matchCtrl)return false;
    }
    return true;
  });
  filtered.forEach(cat=>{
    const relevantThreats=THREATS.filter(t=>t.controls.some(c=>cat.controls.some(cc=>c.toLowerCase().includes(cc.split(' ')[0].toLowerCase()))));
    html+=`<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:12px;overflow:hidden">
      <div style="display:flex;align-items:center;gap:10px;padding:12px 16px;background:${cat.color}20;border-bottom:1px solid var(--border)">
        <div style="width:10px;height:10px;border-radius:50%;background:${cat.dot};flex-shrink:0"></div>
        <span style="font-size:14px;font-weight:600;color:var(--text)">${cat.name}</span>
        <span style="font-size:11px;color:var(--muted);margin-left:auto">${cat.controls.length} controls · mitigates ${relevantThreats.length} threat${relevantThreats.length!==1?'s':''}</span>
      </div>
      <div style="padding:14px 16px">
        <ul class="ctrl-list">${cat.controls.map(c=>`<li class="ctrl-item"><div class="ctrl-dot" style="background:${cat.dot}"></div>${c}</li>`).join('')}</ul>
        ${relevantThreats.length?`<div style="margin-top:12px;padding-top:10px;border-top:1px solid var(--border)"><span style="font-size:11px;color:var(--muted)">Addresses threats: </span>${relevantThreats.map(t=>`<span class="pill ${sevClass(t.sev)}" style="margin:2px">${t.id} ${t.name.split(' ').slice(0,3).join(' ')}…</span>`).join('')}</div>`:''}
      </div>
    </div>`;
  });
  document.getElementById('controls-grid').innerHTML=html||'<p style="color:var(--muted);font-size:13px">No controls match your filter.</p>';
}

function populateControlCatFilter(){
  const fc=document.getElementById('fc-cat');
  CONTROLS_CATS.forEach(c=>{const o=document.createElement('option');o.value=c.name;o.textContent=c.name;fc.appendChild(o)});
}

function showTab(name,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  document.getElementById(name).classList.add('active');
  if(name==='matrix')renderMatrix();
  if(name==='controls')renderControls();
}

renderStats();
renderThreats();
populateControlCatFilter();
</script>
</body>
</html>
