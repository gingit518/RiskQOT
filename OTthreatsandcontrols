<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RiskQ — OT Threat × Controls Matrix</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --green:#1D9E75;--green-dk:#0F6E56;--green-lt:#E1F5EE;--green-bd:#9FE1CB;
  --red:#E24B4A;--red-lt:#FCEBEB;--red-dk:#A32D2D;
  --amber:#BA7517;--amber-lt:#FAEEDA;--amber-dk:#854F0B;
  --blue:#185FA5;--blue-lt:#E6F1FB;--blue-bd:#B5D4F4;
  --purple:#534AB7;--purple-lt:#EEEDFE;--purple-dk:#3C3489;
  --bg:#F7F7F5;--surface:#fff;
  --text:#1A1A18;--muted:#6B6A65;--faint:#B4B2A9;
  --border:rgba(0,0,0,0.1);--radius:10px;--radius-sm:6px
}
body{font-family:-apple-system,"Segoe UI",system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:14px}
.app{max-width:1100px;margin:0 auto;padding:24px 20px}

/* header */
.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:12px}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:36px;height:36px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center}
.logo-mark svg{width:20px;height:20px}
.logo-name{font-size:20px;font-weight:600;letter-spacing:-.4px}
.logo-tag{font-size:12px;color:var(--muted)}
.hdr-right{display:flex;align-items:center;gap:10px}
.badge{font-size:11px;padding:4px 10px;border-radius:20px;font-weight:500}
.badge-green{background:var(--green-lt);color:var(--green-dk);border:1px solid var(--green-bd)}
.badge-count{background:var(--red-lt);color:var(--red-dk);border:1px solid #F7C1C1}

/* tabs */
.tabs{display:flex;gap:2px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:4px;margin-bottom:18px;width:fit-content}
.tab{font-size:13px;padding:7px 16px;cursor:pointer;border-radius:7px;background:none;border:none;color:var(--muted);transition:all .15s;font-weight:400;white-space:nowrap}
.tab.active{background:var(--green);color:#fff;font-weight:500}
.tab:hover:not(.active){background:var(--bg);color:var(--text)}

/* sections */
.sec{display:none}.sec.active{display:block}

/* summary cards */
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-bottom:20px}
.stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.stat-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:4px}
.stat-val{font-size:26px;font-weight:700}
.stat-val.red{color:var(--red)}.stat-val.amber{color:var(--amber)}.stat-val.green{color:var(--green)}.stat-val.blue{color:var(--blue)}.stat-val.purple{color:var(--purple)}

/* filters */
.filter-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:14px}
.filter-bar label{font-size:12px;color:var(--muted)}
.filter-bar select{font-size:12px;padding:5px 8px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text)}
.search-input{font-size:12px;padding:5px 10px;border:1px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text);width:180px}
.search-input:focus,.filter-bar select:focus{outline:none;border-color:var(--green)}

/* threat cards */
.threat-grid{display:flex;flex-direction:column;gap:10px}
.threat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:border .15s}
.threat-card:hover{border-color:var(--green)}
.threat-head{display:flex;align-items:center;gap:12px;padding:14px 16px;cursor:pointer;user-select:none}
.threat-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.threat-meta{flex:1;min-width:0}
.threat-name{font-size:14px;font-weight:600;color:var(--text)}
.threat-sub{font-size:12px;color:var(--muted);margin-top:2px}
.threat-badges{display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.pill{display:inline-block;font-size:11px;padding:3px 8px;border-radius:20px;font-weight:600;white-space:nowrap}
.pill-crit{background:var(--red-lt);color:var(--red-dk)}
.pill-high{background:var(--amber-lt);color:var(--amber-dk)}
.pill-med{background:var(--green-lt);color:var(--green-dk)}
.pill-low{background:var(--blue-lt);color:var(--blue)}
.pill-cat{background:#F1EFE8;color:#444441}
.expand-icon{font-size:18px;color:var(--faint);transition:transform .2s;flex-shrink:0}
.threat-card.open .expand-icon{transform:rotate(180deg)}

.threat-body{display:none;border-top:1px solid var(--border);padding:16px}
.threat-card.open .threat-body{display:block}
.body-desc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:14px}
.body-cols{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:600px){.body-cols{grid-template-columns:1fr}}
.col-head{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.col-head.red{color:var(--red-dk)}
.col-head.green{color:var(--green-dk)}
.ctrl-list{list-style:none;display:flex;flex-direction:column;gap:6px}
.ctrl-item{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--text);line-height:1.45}
.ctrl-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:5px}
.ctrl-dot.green{background:var(--green)}
.ctrl-dot.blue{background:var(--blue)}
.ctrl-dot.amber{background:var(--amber)}
.framework-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:14px;padding-top:12px;border-top:1px solid var(--border)}
.fw-badge{font-size:10px;padding:3px 7px;border-radius:4px;font-weight:600}
.fw-nist{background:#E6F1FB;color:#185FA5}
.fw-iec{background:#EEEDFE;color:#3C3489}
.fw-cisa{background:var(--green-lt);color:var(--green-dk)}
.fw-mitre{background:var(--red-lt);color:var(--red-dk)}

/* matrix view */
.matrix-scroll{overflow-x:auto;margin-bottom:20px}
.matrix-tbl{border-collapse:collapse;min-width:700px;width:100%}
.matrix-tbl th{font-size:11px;font-weight:600;padding:8px 10px;text-align:left;background:var(--bg);border:1px solid var(--border);color:var(--muted);white-space:nowrap}
.matrix-tbl td{padding:9px 10px;border:1px solid var(--border);font-size:12px;vertical-align:top}
.matrix-tbl tr:hover td{background:#F5F5F2}
.dot-cell{display:flex;gap:4px;flex-wrap:wrap}
.ctrl-dot-sm{width:10px;height:10px;border-radius:50%;display:inline-block;cursor:default}
.ctrl-dot-sm.has{background:var(--green)}
.ctrl-dot-sm.none{background:#E0DFDB}

/* legend */
.legend{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:16px}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.legend-dot{width:10px;height:10px;border-radius:50%}
</style>
</head>
<body>
<div class="app">

<div class="hdr">
  <div class="logo">
    <div class="logo-mark">
      <svg viewBox="0 0 20 20" fill="none"><path d="M10 2L17 6V14L10 18L3 14V6L10 2Z" stroke="white" stroke-width="1.5"/><circle cx="10" cy="10" r="3" fill="white"/></svg>
    </div>
    <div><div class="logo-name">RiskQ</div><div class="logo-tag">OT Threat × Controls Matrix</div></div>
  </div>
  <div class="hdr-right">
    <span class="badge badge-count" id="threat-count-badge">22 threats</span>
    <span class="badge badge-green">NIST 800-82 · IEC 62443 · MITRE ATT&CK ICS</span>
  </div>
</div>

<div class="tabs">
  <button class="tab active" onclick="showTab('threats',this)">Threats &amp; controls</button>
  <button class="tab" onclick="showTab('matrix',this)">Mapping matrix</button>
  <button class="tab" onclick="showTab('controls',this)">Controls library</button>
</div>

<!-- THREATS & CONTROLS -->
<div id="threats" class="sec active">
  <div class="stat-row" id="stat-row"></div>
  <div class="filter-bar">
    <label>Filter:</label>
    <select id="f-cat" onchange="renderThreats()"><option value="">All categories</option></select>
    <select id="f-sev" onchange="renderThreats()"><option value="">All severities</option><option>Critical</option><option>High</option><option>Medium</option><option>Low</option></select>
    <select id="f-zone" onchange="renderThreats()"><option value="">All OT zones</option></select>
    <input class="search-input" id="f-search" placeholder="Search threats..." oninput="renderThreats()">
  </div>
  <div class="threat-grid" id="threat-grid"></div>
</div>

<!-- MATRIX -->
<div id="matrix" class="sec">
  <div class="legend">
    <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div>Control applies</div>
    <div class="legend-item"><div class="legend-dot" style="background:#E0DFDB"></div>Not applicable</div>
  </div>
  <div class="matrix-scroll"><table class="matrix-tbl" id="matrix-tbl"></table></div>
</div>

<!-- CONTROLS LIBRARY -->
<div id="controls" class="sec">
  <div class="filter-bar">
    <label>Category:</label>
    <select id="fc-cat" onchange="renderControls()"><option value="">All categories</option></select>
    <input class="search-input" id="fc-search" placeholder="Search controls..." oninput="renderControls()">
  </div>
  <div id="controls-grid"></div>
</div>

</div>

<script>
const THREATS = [
  {
    id:"T01", name:"Ransomware targeting OT/ICS",
