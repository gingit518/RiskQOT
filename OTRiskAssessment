<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RiskQ — OT Risk Assessment</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --green: #1D9E75; --green-dark: #0F6E56; --green-light: #E1F5EE;
    --red: #E24B4A; --red-light: #FCEBEB; --red-dark: #A32D2D;
    --amber: #BA7517; --amber-light: #FAEEDA; --amber-dark: #854F0B;
    --blue: #185FA5; --blue-light: #E6F1FB;
    --bg: #F9F9F7; --surface: #FFFFFF;
    --text: #1A1A18; --muted: #6B6A65; --faint: #AFAFAB;
    --border: rgba(0,0,0,0.1);
    --radius: 10px; --radius-sm: 6px;
  }
  body { font-family: -apple-system, "Segoe UI", system-ui, sans-serif; background: var(--bg); color: var(--text); font-size: 14px; min-height: 100vh; }

  .app { max-width: 900px; margin: 0 auto; padding: 24px 20px; }

  .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-mark { width: 36px; height: 36px; background: var(--green); border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .logo-mark svg { width: 20px; height: 20px; }
  .logo-name { font-size: 20px; font-weight: 600; letter-spacing: -0.4px; }
  .logo-tag { font-size: 12px; color: var(--muted); }
  .status-badge { font-size: 11px; padding: 4px 10px; border-radius: 20px; background: var(--green-light); color: var(--green-dark); border: 1px solid #9FE1CB; font-weight: 500; }

  .tabs { display: flex; gap: 2px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 4px; margin-bottom: 20px; }
  .tab { flex: 1; font-size: 13px; padding: 8px 12px; cursor: pointer; border-radius: 7px; background: none; border: none; color: var(--muted); transition: all 0.15s; font-weight: 400; }
  .tab.active { background: var(--green); color: white; font-weight: 500; }
  .tab:hover:not(.active) { background: var(--bg); color: var(--text); }

  .section { display: none; }
  .section.active { display: block; }

  .grid3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; }
  .card-label { font-size: 11px; color: var(--muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .card-val { font-size: 28px; font-weight: 600; }
  .card-val.red { color: var(--red); }
  .card-val.amber { color: var(--amber); }
  .card-val.green { color: var(--green); }

  .section-label { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 12px; letter-spacing: -0.1px; }

  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; color: var(--muted); letter-spacing: 0.4px; text-transform: uppercase; border-bottom: 1px solid var(--border); background: var(--bg); }
  td { padding: 11px 12px; border-bottom: 1px solid var(--border); color: var(--text); font-size: 13px; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #F5F5F2; }
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 20px; }

  .pill { display: inline-block; font-size: 11px; padding: 3px 8px; border-radius: 20px; font-weight: 600; letter-spacing: 0.2px; }
  .pill.Critical { background: var(--red-light); color: var(--red-dark); }
  .pill.High { background: var(--amber-light); color: var(--amber-dark); }
  .pill.Medium { background: var(--green-light); color: var(--green-dark); }
  .pill.Low { background: var(--blue-light); color: var(--blue); }

  .bar-wrap { display: flex; align-items: center; gap: 8px; }
  .bar { height: 6px; flex: 1; background: #EBEBEA; border-radius: 3px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; }
  .bar-num { font-size: 12px; font-weight: 600; min-width: 22px; text-align: right; }

  .detail-row { display: none; background: #F9F9F7; }
  .detail-inner { padding: 12px 16px; font-size: 13px; }
  .detail-inner strong { color: var(--text); }
  .mit-list { list-style: none; margin-top: 6px; }
  .mit-list li { padding: 3px 0 3px 14px; position: relative; color: var(--muted); }
  .mit-list li::before { content: ""; position: absolute; left: 2px; top: 9px; width: 6px; height: 6px; border-radius: 50%; background: var(--green); }

  .filter-row { display: flex; gap: 8px; align-items: center; margin-bottom: 14px; }
  .filter-row label { font-size: 12px; color: var(--muted); }
  .filter-row select { font-size: 12px; padding: 5px 8px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); color: var(--text); }

  .matrix-wrap { overflow-x: auto; }
  .matrix-grid { display: grid; grid-template-columns: 36px repeat(5, 1fr); gap: 3px; min-width: 320px; }
  .matrix-cell { height: 48px; border-radius: 5px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; cursor: pointer; transition: opacity 0.1s; }
  .matrix-cell:hover { opacity: 0.8; }
  .matrix-axis-cell { background: none; font-size: 11px; color: var(--muted); }
  .mc-low { background: var(--blue-light); color: var(--blue); }
  .mc-med { background: var(--green-light); color: var(--green-dark); }
  .mc-high { background: var(--amber-light); color: var(--amber-dark); }
  .mc-crit { background: var(--red-light); color: var(--red-dark); }

  .legend { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 14px; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--muted); }
  .legend-swatch { width: 12px; height: 12px; border-radius: 3px; }

  .matrix-info { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; margin-top: 14px; font-size: 13px; min-height: 60px; color: var(--muted); }

  .form-label { font-size: 12px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.4px; display: block; margin-bottom: 5px; }
  .form-row { margin-bottom: 14px; }
  .form-row input[type=text], .form-row select, .form-row textarea {
    width: 100%; padding: 9px 11px; border: 1px solid var(--border); border-radius: var(--radius-sm);
    font-size: 13px; background: var(--surface); color: var(--text); transition: border 0.15s;
  }
  .form-row input:focus, .form-row select:focus, .form-row textarea:focus { outline: none; border-color: var(--green); }
  .form-row textarea { resize: vertical; min-height: 72px; }
  .slider-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .slider-label { font-size: 13px; color: var(--muted); min-width: 140px; }
  .slider-row input[type=range] { flex: 1; accent-color: var(--green); }
  .slider-val { font-size: 14px; font-weight: 600; min-width: 20px; }

  .score-preview { display: flex; align-items: center; gap: 14px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 16px; margin: 12px 0 16px; }
  .score-big { font-size: 32px; font-weight: 700; }
  .score-desc { font-size: 12px; color: var(--muted); }

  .btn-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .btn { font-size: 13px; padding: 9px 18px; border-radius: var(--radius-sm); cursor: pointer; font-weight: 500; transition: all 0.15s; }
  .btn-primary { background: var(--green); color: white; border: none; }
  .btn-primary:hover { background: var(--green-dark); }
  .btn-ghost { background: var(--surface); color: var(--text); border: 1px solid var(--border); }
  .btn-ghost:hover { background: var(--bg); }
  .btn-ai { background: var(--surface); color: var(--blue); border: 1px solid var(--border); }

  .axis-label { font-size: 11px; color: var(--muted); text-align: center; margin-bottom: 4px; }
  .y-axis-wrap { display: flex; gap: 8px; align-items: flex-start; }
  .y-label { writing-mode: vertical-lr; transform: rotate(180deg); font-size: 11px; color: var(--muted); padding-top: 40px; }
</style>
</head>
<body>
<div class="app">

  <div class="header">
    <div class="logo">
      <div class="logo-mark">
        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 2L17 6V14L10 18L3 14V6L10 2Z" stroke="white" stroke-width="1.5" fill="none"/>
          <circle cx="10" cy="10" r="3" fill="white"/>
        </svg>
      </div>
      <div>
        <div class="logo-name">RiskQ</div>
        <div class="logo-tag">OT Risk Assessment</div>
      </div>
    </div>
    <span class="status-badge">Assessment active</span>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="showTab('dashboard', this)">Dashboard</button>
    <button class="tab" onclick="showTab('register', this)">Risk register</button>
    <button class="tab" onclick="showTab('matrix', this)">Risk matrix</button>
    <button class="tab" onclick="showTab('add', this)">+ Add risk</button>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" class="section active">
    <div class="grid3" id="stats-grid"></div>
    <p class="section-label">Top risks by score</p>
    <div class="table-wrap"><table><thead><tr><th>Risk</th><th>Zone</th><th>Severity</th><th>Score</th></tr></thead><tbody id="top-body"></tbody></table></div>
    <p class="section-label">Exposure by category</p>
    <div id="cat-bars"></div>
  </div>

  <!-- REGISTER -->
  <div id="register" class="section">
    <div class="filter-row">
      <label>Filter:</label>
      <select id="f-sev" onchange="renderRegister()"><option value="">All severities</option><option>Critical</option><option>High</option><option>Medium</option><option>Low</option></select>
      <select id="f-zone" onchange="renderRegister()"><option value="">All zones</option><option>Control</option><option>Field</option><option>Network</option><option>Safety</option></select>
    </div>
    <div class="table-wrap"><table><thead><tr><th>ID</th><th>Risk description</th><th>Zone</th><th>L</th><th>I</th><th>Score</th><th>Severity</th></tr></thead><tbody id="reg-body"></tbody></table></div>
  </div>

  <!-- MATRIX -->
  <div id="matrix" class="section">
    <p class="section-label">Risk matrix — likelihood × impact</p>
    <div class="legend">
      <div class="legend-item"><div class="legend-swatch" style="background:var(--blue-light);border:1px solid #B5D4F4"></div>Low (1–4)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:var(--green-light);border:1px solid #9FE1CB"></div>Medium (5–9)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:var(--amber-light);border:1px solid #FAC775"></div>High (10–16)</div>
      <div class="legend-item"><div class="legend-swatch" style="background:var(--red-light);border:1px solid #F7C1C1"></div>Critical (17–25)</div>
    </div>
    <p class="axis-label">Impact →</p>
    <div class="y-axis-wrap">
      <div class="y-label">← Likelihood</div>
      <div class="matrix-wrap" style="flex:1">
        <div class="matrix-grid" id="m-grid"></div>
      </div>
    </div>
    <div class="matrix-info" id="m-info">Click any cell to view risks in that zone.</div>
  </div>

  <!-- ADD RISK -->
  <div id="add" class="section">
    <p class="section-label">Add new OT risk</p>
    <div class="grid2">
      <div class="form-row"><label class="form-label">Risk description</label><input type="text" id="n-desc" placeholder="e.g. Unpatched SCADA firmware"></div>
      <div class="form-row"><label class="form-label">OT zone</label><select id="n-zone"><option>Control</option><option>Field</option><option>Network</option><option>Safety</option></select></div>
    </div>
    <div class="grid2">
      <div class="form-row"><label class="form-label">Category</label><select id="n-cat"><option>Cyber</option><option>Physical</option><option>Process</option><option>Supply chain</option><option>Insider threat</option></select></div>
      <div class="form-row"><label class="form-label">Asset type</label><select id="n-asset"><option>PLC / RTU</option><option>HMI</option><option>Historian</option><option>Engineering workstation</option><option>Network switch</option><option>Safety system</option><option>Sensor / actuator</option></select></div>
    </div>
    <div class="slider-row">
      <span class="slider-label">Likelihood (1–5)</span>
      <input type="range" min="1" max="5" step="1" value="3" id="n-l" oninput="updatePreview()">
      <span class="slider-val" id="lv">3</span>
    </div>
    <div class="slider-row">
      <span class="slider-label">Impact (1–5)</span>
      <input type="range" min="1" max="5" step="1" value="3" id="n-i" oninput="updatePreview()">
      <span class="slider-val" id="iv">3</span>
    </div>
    <div class="score-preview">
      <div>
        <div class="score-desc">Calculated score</div>
        <div class="score-big" id="prev-score">9</div>
      </div>
      <span class="pill Medium" id="prev-pill">Medium</span>
    </div>
    <div class="form-row"><label class="form-label">Existing controls</label><textarea id="n-ctrl" placeholder="Describe controls currently in place..."></textarea></div>
    <div class="form-row"><label class="form-label">Mitigation actions (one per line)</label><textarea id="n-mit" placeholder="List recommended mitigations..."></textarea></div>
    <div class="btn-row">
      <button class="btn btn-primary" onclick="addRisk()">Add to register</button>
      <button class="btn btn-ghost" onclick="clearForm()">Clear</button>
    </div>
  </div>

</div>

<script>
const risks = [
  {id:"OT-001",desc:"Unpatched SCADA firmware vulnerabilities",zone:"Control",cat:"Cyber",asset:"HMI",l:4,i:5,ctrl:"Air-gapped network segment",mit:["Apply vendor patches Q2","Enable integrity monitoring","Restrict USB ports"]},
  {id:"OT-002",desc:"Lack of segmentation between IT and OT networks",zone:"Network",cat:"Cyber",asset:"Network switch",l:5,i:4,ctrl:"Partial VLAN separation",mit:["Implement Purdue model segmentation","Deploy OT-specific firewall","Remove legacy bridging"]},
  {id:"OT-003",desc:"Default credentials on field PLCs",zone:"Field",cat:"Cyber",asset:"PLC / RTU",l:4,i:4,ctrl:"Manual audit in progress",mit:["Rotate all default passwords","Enforce credential policy","Deploy PAM solution"]},
  {id:"OT-004",desc:"Inadequate backup for historian data",zone:"Control",cat:"Process",asset:"Historian",l:3,i:3,ctrl:"Daily backups to local NAS",mit:["Offsite backup replication","Test recovery procedures quarterly"]},
  {id:"OT-005",desc:"Insider access to safety instrumented systems",zone:"Safety",cat:"Insider threat",asset:"Safety system",l:2,i:5,ctrl:"Role-based access in place",mit:["Dual authorisation for SIS changes","Audit access logs monthly"]},
  {id:"OT-006",desc:"Remote access via unmanaged VPN endpoints",zone:"Network",cat:"Cyber",asset:"Engineering workstation",l:4,i:3,ctrl:"VPN with MFA enabled",mit:["Enforce endpoint compliance checks","Replace legacy VPN solution"]},
  {id:"OT-007",desc:"Counterfeit components in supply chain",zone:"Field",cat:"Supply chain",asset:"Sensor / actuator",l:2,i:3,ctrl:"Approved vendor list",mit:["Introduce hardware verification","Audit supplier contracts"]},
  {id:"OT-008",desc:"No anomaly detection on OT network traffic",zone:"Network",cat:"Cyber",asset:"Network switch",l:3,i:4,ctrl:"Manual monitoring only",mit:["Deploy passive OT NDR tool","Define baseline traffic profiles"]}
];
let nextId = 9;

const sc = r => r.l * r.i;
const sev = s => s >= 17 ? "Critical" : s >= 10 ? "High" : s >= 5 ? "Medium" : "Low";
const barCol = s => s === "Critical" ? "#E24B4A" : s === "High" ? "#BA7517" : s === "Medium" ? "#1D9E75" : "#185FA5";

function showTab(name, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  el.classList.add('active');
  document.getElementById(name).classList.add('active');
  if (name === 'dashboard') renderDashboard();
  if (name === 'register') renderRegister();
  if (name === 'matrix') renderMatrix();
}

function renderDashboard() {
  const total = risks.length;
  const critical = risks.filter(r => ["Critical","High"].includes(sev(sc(r)))).length;
  const avg = (risks.reduce((a,r) => a + sc(r), 0) / risks.length).toFixed(1);
  document.getElementById('stats-grid').innerHTML = `
    <div class="card"><div class="card-label">Total risks</div><div class="card-val">${total}</div></div>
    <div class="card"><div class="card-label">Critical / High</div><div class="card-val red">${critical}</div></div>
    <div class="card"><div class="card-label">Avg score</div><div class="card-val amber">${avg}</div></div>`;

  const sorted = [...risks].sort((a,b) => sc(b)-sc(a)).slice(0,5);
  document.getElementById('top-body').innerHTML = sorted.map(r => {
    const s = sc(r), sv = sev(s), c = barCol(sv);
    return `<tr><td>${r.desc}</td><td style="color:#888">${r.zone}</td>
      <td><span class="pill ${sv}">${sv}</span></td>
      <td><div class="bar-wrap"><div class="bar"><div class="bar-fill" style="width:${s/25*100}%;background:${c}"></div></div><span class="bar-num" style="color:${c}">${s}</span></div></td></tr>`;
  }).join('');

  const cats = {};
  risks.forEach(r => { cats[r.cat] = (cats[r.cat]||0) + sc(r); });
  const maxV = Math.max(...Object.values(cats));
  document.getElementById('cat-bars').innerHTML = Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([cat,val]) => {
    const avgSev = sev(val / risks.filter(r=>r.cat===cat).length);
    const c = barCol(avgSev);
    return `<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
      <span style="font-size:12px;color:#888;min-width:120px">${cat}</span>
      <div class="bar" style="flex:1"><div class="bar-fill" style="width:${val/maxV*100}%;background:${c}"></div></div>
      <span style="font-size:12px;font-weight:600;min-width:24px;text-align:right;color:${c}">${val}</span></div>`;
  }).join('');
}

function renderRegister() {
  const fs = document.getElementById('f-sev').value;
  const fz = document.getElementById('f-zone').value;
  const filtered = risks.filter(r => (!fs || sev(sc(r)) === fs) && (!fz || r.zone === fz));
  document.getElementById('reg-body').innerHTML = filtered.map(r => {
    const s = sc(r), sv = sev(s), c = barCol(sv);
    return `<tr style="cursor:pointer" onclick="toggleDetail('d-${r.id}')">
      <td style="font-size:11px;color:#888;white-space:nowrap">${r.id}</td>
      <td>${r.desc}</td><td style="color:#888">${r.zone}</td>
      <td style="text-align:center">${r.l}</td><td style="text-align:center">${r.i}</td>
      <td><span style="font-weight:600;color:${c}">${s}</span></td>
      <td><span class="pill ${sv}">${sv}</span></td></tr>
    <tr class="detail-row" id="d-${r.id}"><td colspan="7">
      <div class="detail-inner">
        <strong>Controls:</strong> ${r.ctrl}<br>
        <strong style="display:block;margin-top:8px">Mitigations:</strong>
        <ul class="mit-list">${r.mit.map(m=>`<li>${m}</li>`).join('')}</ul>
      </div></td></tr>`;
  }).join('');
}

function toggleDetail(id) {
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'table-row' ? 'none' : 'table-row';
}

function renderMatrix() {
  const grid = document.getElementById('m-grid');
  let html = '<div class="matrix-cell matrix-axis-cell"></div>';
  [1,2,3,4,5].forEach(n => { html += `<div class="matrix-cell matrix-axis-cell">${n}</div>`; });
  for (let li = 5; li >= 1; li--) {
    html += `<div class="matrix-cell matrix-axis-cell">${li}</div>`;
    for (let im = 1; im <= 5; im++) {
      const s = li * im, sv = sev(s);
      const cls = sv === 'Critical' ? 'mc-crit' : sv === 'High' ? 'mc-high' : sv === 'Medium' ? 'mc-med' : 'mc-low';
      const count = risks.filter(r => r.l === li && r.i === im).length;
      html += `<div class="matrix-cell ${cls}" onclick="showCell(${li},${im})">${count > 0 ? `<span style="font-size:14px;font-weight:700">${count}</span>` : s}</div>`;
    }
  }
  grid.innerHTML = html;
}

function showCell(li, im) {
  const cell = risks.filter(r => r.l === li && r.i === im);
  const el = document.getElementById('m-info');
  if (!cell.length) { el.innerHTML = `<span style="color:#888">No risks at likelihood ${li}, impact ${im} (score: ${li*im}).</span>`; return; }
  el.innerHTML = `<strong>Risks at L${li} × I${im} &mdash; score ${li*im}:</strong>
    <ul class="mit-list" style="margin-top:8px">${cell.map(r=>`<li><strong>${r.id}:</strong> ${r.desc} <span class="pill ${sev(sc(r))}" style="margin-left:6px">${sev(sc(r))}</span></li>`).join('')}</ul>`;
}

function updatePreview() {
  const l = +document.getElementById('n-l').value;
  const i = +document.getElementById('n-i').value;
  document.getElementById('lv').textContent = l;
  document.getElementById('iv').textContent = i;
  const s = l * i, sv = sev(s);
  const el = document.getElementById('prev-score');
  el.textContent = s;
  el.style.color = barCol(sv);
  const pill = document.getElementById('prev-pill');
  pill.textContent = sv;
  pill.className = 'pill ' + sv;
}

function addRisk() {
  const desc = document.getElementById('n-desc').value.trim();
  if (!desc) { alert('Please enter a risk description.'); return; }
  const l = +document.getElementById('n-l').value;
  const i = +document.getElementById('n-i').value;
  const ctrl = document.getElementById('n-ctrl').value.trim() || 'None documented';
  const mit = document.getElementById('n-mit').value.trim().split('\n').filter(Boolean);
  const id = `OT-${String(nextId++).padStart(3,'0')}`;
  risks.push({ id, desc, zone: document.getElementById('n-zone').value, cat: document.getElementById('n-cat').value, asset: document.getElementById('n-asset').value, l, i, ctrl, mit: mit.length ? mit : ['No mitigations specified'] });
  clearForm();
  document.querySelector('.tab:nth-child(2)').click();
}

function clearForm() {
  ['n-desc','n-ctrl','n-mit'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('n-l').value = 3;
  document.getElementById('n-i').value = 3;
  updatePreview();
}

renderDashboard();
</script>
</body>
</html>
